# Anthropic — required for the agent loop
ANTHROPIC_API_KEY=

# Upstash Redis — required for production rate-limit + daily USD cap.
# Without these set, guardrails are disabled (fine for local dev).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Long random string. Set the forge_admin cookie to this value to bypass
# the rate limit and daily cap. Useful for the owner / demoing.
FORGE_ADMIN_KEY=

# Daily USD cap across ALL visitors (defaults to 10 if unset).
# Once today's spend hits this, the API returns 429 until UTC midnight.
FORGE_DAILY_USD_CAP=10

# Future Phase 7 adapters — not used yet (fixtures cover the same ground).
GITHUB_TOKEN=
SENTRY_AUTH_TOKEN=
