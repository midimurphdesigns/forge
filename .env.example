# Anthropic — required for the agent loop
ANTHROPIC_API_KEY=

# Phase 4+: GitHub source-file fetcher
GITHUB_TOKEN=

# Phase 5+: real Sentry issue parsing
SENTRY_AUTH_TOKEN=

# Phase 3+: Upstash for resumable-stream session state, rate limit, USD cap
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Owner-bypass cookie (set this to a long random string)
FORGE_ADMIN_KEY=

# Daily USD cap across all visitors (defaults to 10 if unset)
FORGE_DAILY_USD_CAP=10
